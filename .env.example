# SOPilot local environment template.
# Copy to .env for local use only. Never commit real API keys or trial codes.

# Live model providers
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_PLANT_DOCTOR_AGENT_ID=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_AGENT_PUBLIC=false

# Plant Doctor hosted/local web app
PLANT_DOCTOR_TRIAL_CODE=
PLANT_DOCTOR_APP_TOKEN=
PLANT_DOCTOR_API_URL=
PLANT_DOCTOR_CORS_ORIGINS=
PLANT_DOCTOR_AUTO_APPROVE=false
PLANT_DOCTOR_SKIP_LOCAL_REPORT_WRITE=false
PLANT_DOCTOR_MAX_UPLOAD_BYTES=8388608

# API runtime
SOPILOT_ENV=local
SOPILOT_ENABLE_API_DOCS=true
